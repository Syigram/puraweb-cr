{
  "name": "ContactRequest",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Client's full name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Client's email address"
    },
    "company": {
      "type": "string",
      "description": "Client's company name"
    },
    "phone": {
      "type": "string",
      "description": "Client's phone number"
    },
    "service_interest": {
      "type": "string",
      "enum": [
        "web_development",
        "ecommerce",
        "both",
        "custom"
      ],
      "description": "Type of service interested in"
    },
    "message": {
      "type": "string",
      "description": "Client's message or requirements"
    },
    "status": {
      "type": "string",
      "enum": [
        "new",
        "contacted",
        "in_progress",
        "closed"
      ],
      "default": "new",
      "description": "Status of the contact request"
    }
  },
  "required": [
    "name",
    "email",
    "message"
  ]
}